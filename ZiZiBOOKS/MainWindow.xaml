<Window x:Class="ZiZiBOOKS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZiZiBOOKS" x:Name="ZiziWin"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="Manual" 
        SizeToContent="WidthAndHeight"
        Closing="Window_Closing" LocationChanged="Window_LocationChanged">

    <Window.Resources>
        <Style x:Key="SemiModeStyle" TargetType="Button">
            <Setter Property="Background" Value="#25FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Margin="10,0">
                                <Image Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTileButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="#55FFFFFF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigInput" TargetType="TextBox">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#EE1A1A1B" CornerRadius="15" BorderBrush="#44FFFFFF" BorderThickness="1.5">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="ZiZiBOOKS Modern" Foreground="#66FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="15,0" IsHitTestVisible="False"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="⚙" FontFamily="Segoe UI Symbol" FontSize="16" Style="{StaticResource IconButtonStyle}" Click="ConfigButton_Click"/>
                    <Button Content="" FontFamily="Segoe MDL2 Assets" FontSize="12" Style="{StaticResource IconButtonStyle}" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="10">
                <Grid>
                    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Hidden" CanContentScroll="False">
                        <StackPanel x:Name="SemiContainer" Visibility="Visible"/>
                    </ScrollViewer>
                    <Separator x:Name="InsertIndicator" 
                               Background="Cyan" 
                               Height="2" 
                               VerticalAlignment="Top" 
                               Visibility="Collapsed" 
                               IsHitTestVisible="False"/>
                </Grid>
                <UniformGrid x:Name="MajiContainer" Columns="2" Visibility="Collapsed"/>
            </Grid>

            <Grid x:Name="ConfigPanel" Grid.Row="1" Background="#F91E1E1E" Visibility="Collapsed" Width="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ConfigMainScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15,10">
                            <TextBlock Text="ZiZiBOOKS - 設定" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <TextBlock Text="現在のブックマーク" Foreground="Cyan" FontSize="11" Margin="0,5,0,2"/>
                            <ScrollViewer x:Name="ConfigListScroll" MaxHeight="160" VerticalScrollBarVisibility="Auto" Background="#0AFFFFFF">
                                <StackPanel x:Name="EditListContainer"/>
                            </ScrollViewer>

                            <Separator Background="#33FFFFFF" Margin="0,10"/>

                            <StackPanel Background="Transparent" AllowDrop="True" PreviewDragOver="EditArea_DragOver" Drop="EditArea_Drop">
                                <TextBlock x:Name="EditTitle" Text="項目の追加 / 編集" Foreground="Cyan" FontSize="11" Margin="0,5,0,5"/>

                                <TextBlock Text="名前:" Foreground="White" FontSize="10"/>
                                <TextBox x:Name="NameBox" Style="{StaticResource ConfigInput}"/>

                                <TextBlock Text="URL / 実行パス:" Foreground="White" FontSize="10"/>
                                <TextBox x:Name="UrlBox" Style="{StaticResource ConfigInput}"/>

                                <TextBlock Text="アイコンパス (任意):" Foreground="White" FontSize="10"/>
                                <TextBox x:Name="IconPathBox" Style="{StaticResource ConfigInput}"/>

                                <TextBlock Text="メモ:" Foreground="White" FontSize="10"/>
                                <TextBox x:Name="MemoBox" Style="{StaticResource ConfigInput}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="AddUpdateBtn" Content="追加/更新" Background="#28a745" Foreground="White" Padding="15,4" Cursor="Hand" Click="AddUpdate_Click"/>
                                <Button x:Name="CancelEditBtn" Content="キャンセル" Background="#666666" Foreground="White" Padding="10,4" Margin="10,0,0,0" Visibility="Collapsed" Cursor="Hand" Click="CancelEdit_Click"/>
                            </StackPanel>

                            <Separator Background="#33FFFFFF" Margin="0,10"/>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="表示設定" Foreground="Cyan" FontSize="11" Margin="0,0,0,3"/>
                                    <CheckBox x:Name="MajiModeCheck" Content="タイル表示" Foreground="White" FontSize="10" Margin="0,2" Checked="MajiModeCheck_Changed" Unchecked="MajiModeCheck_Changed"/>
                                    <CheckBox x:Name="TopmostCheck" Content="最前面" Foreground="White" FontSize="10" Margin="0,2" Checked="TopmostCheck_Changed" Unchecked="TopmostCheck_Changed"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <TextBlock Text="字:" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="FontSizeBox" Width="30" Style="{StaticResource ConfigInput}" Margin="3,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Margin="5,0,0,0">
                                    <TextBlock Text="焼き付き防止" Foreground="Yellow" FontSize="11" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="秒:" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="IdleSecondsBox" Width="30" Style="{StaticResource ConfigInput}" Margin="3,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="不透明:" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBox x:Name="IdleOpacityBox" Width="35" Style="{StaticResource ConfigInput}" Margin="3,0,0,0"/>
                                    </StackPanel>
                                    <Button Content="設定保存" Background="#28a745" Foreground="White" Padding="8,2" HorizontalAlignment="Right" Margin="0,2,0,0" Cursor="Hand" Click="SaveSettings_Click"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="#F91E1E1E" BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0" Padding="10">
                        <StackPanel>
                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                <Button Content="出力" Background="#0078D4" Foreground="White" Padding="5,3" Margin="0,0,4,0" Cursor="Hand" Click="ExportConfig_Click"/>
                                <Button Content="入力" Background="#0078D4" Foreground="White" Padding="5,3" Margin="4,0,0,0" Cursor="Hand" Click="ImportConfig_Click"/>
                            </UniformGrid>
                            <Button Content="設定を閉じる" Background="#555555" Foreground="White" Padding="0,6" HorizontalAlignment="Stretch" Cursor="Hand" Click="ConfigButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>