<Window x:Class="ZiZiBOOKS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZiZiBOOKS" x:Name="ZiziWin"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="Manual" 
        SizeToContent="WidthAndHeight"
        Closing="Window_Closing" LocationChanged="Window_LocationChanged">

    <Window.Resources>

        <!-- ===== メイン画面：ランチャーボタン ===== -->
        <Style x:Key="SemiModeStyle" TargetType="Button">
            <Setter Property="Background" Value="#25FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Margin="10,0">
                                <Image Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#38FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTileButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="#55FFFFFF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ヘッダーアイコンボタン（⚙ / 閉じる） ===== -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 設定画面：カード / 見出し / ラベル ===== -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#12FFFFFF"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#818CF8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- ===== 設定画面：入力欄（フォーカス時にアクセントカラー） ===== -->
        <Style x:Key="ConfigInput" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1B26"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="CaretBrush" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#2A2C3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#40435C"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 設定画面：トグルスイッチ（CheckBoxを置き換え） ===== -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track" Grid.Column="0" Width="34" Height="18" CornerRadius="9" Background="#33FFFFFF" VerticalAlignment="Center">
                                <Border x:Name="Thumb" Width="14" Height="14" CornerRadius="7" Background="#D1D5DB" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#6366F1"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 設定画面：ボタン（アクセント / セカンダリ） ===== -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#7A7DF5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#4F52D6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Background" Value="#2A2C3D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#383B52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1F212E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22D6A5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#0B9268"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="MainBorder" Background="#EE15161F" CornerRadius="15" BorderBrush="#332A2D3D" BorderThickness="1.5">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="ZiZiBOOKS" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0" IsHitTestVisible="False"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="⚙" FontFamily="Segoe UI Symbol" FontSize="15" Style="{StaticResource IconButtonStyle}" Click="ConfigButton_Click"/>
                    <Button Content="" FontFamily="Segoe MDL2 Assets" FontSize="11" Style="{StaticResource IconButtonStyle}" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="10">
                <Grid>
                    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Hidden" CanContentScroll="False">
                        <StackPanel x:Name="SemiContainer" Visibility="Visible"/>
                    </ScrollViewer>
                    <Separator x:Name="InsertIndicator" 
                               Background="Cyan" 
                               Height="2" 
                               VerticalAlignment="Top" 
                               Visibility="Collapsed" 
                               IsHitTestVisible="False"/>
                </Grid>
                <UniformGrid x:Name="MajiContainer" Columns="2" Visibility="Collapsed"/>
            </Grid>

            <!-- ===== 設定パネル（SaaS風カードレイアウト） ===== -->
            <Grid x:Name="ConfigPanel" Grid.Row="1" Background="#F5121219" Visibility="Collapsed" Width="330">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ConfigMainScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,10">

                            <TextBlock Text="設定" Foreground="White" FontSize="15" FontWeight="Bold" Margin="2,0,0,10"/>

                            <!-- ブックマーク一覧 -->
                            <Border Style="{StaticResource SectionCard}">
                                <StackPanel>
                                    <TextBlock Text="現在のブックマーク" Style="{StaticResource SectionHeader}"/>
                                    <ScrollViewer x:Name="ConfigListScroll" MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="EditListContainer"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <!-- 項目の追加/編集 -->
                            <Border Style="{StaticResource SectionCard}" AllowDrop="True" PreviewDragOver="EditArea_DragOver" Drop="EditArea_Drop">
                                <StackPanel>
                                    <TextBlock x:Name="EditTitle" Text="項目の追加 / 編集" Style="{StaticResource SectionHeader}"/>

                                    <TextBlock Text="名前" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="NameBox" Style="{StaticResource ConfigInput}"/>

                                    <TextBlock Text="URL / 実行パス" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="UrlBox" Style="{StaticResource ConfigInput}"/>

                                    <TextBlock Text="アイコンパス（任意）" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="IconPathBox" Style="{StaticResource ConfigInput}"/>

                                    <TextBlock Text="メモ" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="MemoBox" Style="{StaticResource ConfigInput}" Margin="0"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button x:Name="AddUpdateBtn" Content="追加 / 更新" Style="{StaticResource SuccessButtonStyle}" Click="AddUpdate_Click"/>
                                        <Button x:Name="CancelEditBtn" Content="キャンセル" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Visibility="Collapsed" Click="CancelEdit_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 表示設定 / 焼き付き防止 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="表示設定" Style="{StaticResource SectionHeader}"/>
                                        <CheckBox x:Name="MajiModeCheck" Content="タイル表示" Style="{StaticResource ToggleSwitchStyle}" Checked="MajiModeCheck_Changed" Unchecked="MajiModeCheck_Changed"/>
                                        <CheckBox x:Name="TopmostCheck" Content="最前面" Style="{StaticResource ToggleSwitchStyle}" Checked="TopmostCheck_Changed" Unchecked="TopmostCheck_Changed"/>
                                        <CheckBox x:Name="HoverTopmostCheck" Content="ホバー時最前面" Style="{StaticResource ToggleSwitchStyle}" Checked="HoverTopmostCheck_Changed" Unchecked="HoverTopmostCheck_Changed"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="文字サイズ" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0"/>
                                            <TextBox x:Name="FontSizeBox" Width="34" Style="{StaticResource ConfigInput}" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="焼き付き防止" Foreground="#FBBF24" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBlock Text="放置秒数" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="IdleSecondsBox" Style="{StaticResource ConfigInput}"/>
                                        <TextBlock Text="不透明度" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="IdleOpacityBox" Style="{StaticResource ConfigInput}" Margin="0,0,0,8"/>
                                        <Button Content="設定保存" Style="{StaticResource SuccessButtonStyle}" HorizontalAlignment="Right" Padding="10,5" Click="SaveSettings_Click"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="#F5121219" BorderBrush="#1AFFFFFF" BorderThickness="0,1,0,0" Padding="12,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="エクスポート" Style="{StaticResource SecondaryButtonStyle}" Padding="0,7" Click="ExportConfig_Click"/>
                                <Button Grid.Column="2" Content="インポート" Style="{StaticResource SecondaryButtonStyle}" Padding="0,7" Click="ImportConfig_Click"/>
                            </Grid>
                            <Button Content="設定を閉じる" Style="{StaticResource AccentButtonStyle}" Padding="0,8" HorizontalAlignment="Stretch" Click="ConfigButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
